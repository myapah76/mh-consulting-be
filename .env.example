SPRING_PROFILES_ACTIVE=dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mh_consulting
DB_USERNAME=mh_consulting
DB_PASSWORD=change-me


FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_URL=http://localhost:3000/admin/reset-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-long-password
ADMIN_FULL_NAME=MH Consulting Administrator


SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Transitional fallback when DB credentials are not configured.
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-google-app-password
# Required for encrypting SMTP credentials stored in PostgreSQL.
# Must decode to exactly 32 random bytes. Never commit the real value.
EMAIL_CREDENTIALS_ENCRYPTION_KEY=
SMTP_AUTH=true
SMTP_ENABLE_SSL=true
SMTP_IMPLICIT_SSL=false
SMTP_FROM_EMAIL=your-gmail-address@gmail.com
SMTP_FROM_NAME=MH Consulting

CONSULTATION_RECIPIENT_EMAIL=info@mhconsulting.vn

SESSION_COOKIE_SECURE=false
SWAGGER_ENABLED=true
